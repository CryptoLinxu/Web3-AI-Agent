# ============================================
# AI 模型配置
# ============================================

# 默认模型提供商 (openai | anthropic)
DEFAULT_MODEL_PROVIDER=openai

# --------------------------------------------
# OpenAI 配置（也兼容 DeepSeek、Groq 等 OpenAI 接口服务）
# --------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo
# OPENAI_BASE_URL=https://api.openai.com/v1  # 可选，用于代理或其他兼容服务
# OPENAI_TEMPERATURE=0.7  # 可选，默认 0.7
# OPENAI_MAX_TOKENS=2000  # 可选，默认 2000

# DeepSeek 配置示例（完全免费，兼容 OpenAI 接口）
# DEFAULT_MODEL_PROVIDER=openai
# OPENAI_API_KEY=sk-your_deepseek_api_key_here
# OPENAI_MODEL=deepseek-chat
# OPENAI_BASE_URL=https://api.deepseek.com  # 注意：不要加 /v1

# --------------------------------------------
# Anthropic 配置（可选）
# --------------------------------------------
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-3-sonnet-20240229
# ANTHROPIC_BASE_URL=https://api.anthropic.com  # 可选
# ANTHROPIC_TEMPERATURE=0.7  # 可选，默认 0.7
# ANTHROPIC_MAX_TOKENS=2000  # 可选，默认 2000

# ============================================
# Web3 配置
# ============================================

# Ethereum RPC 配置（可选，默认使用公共节点）
# 可以使用 Alchemy、Infura 或 QuickNode 等服务
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ============================================
# 应用配置
# ============================================
APP_VERSION=0.1.0
